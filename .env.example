# ─────────────────────────────────────────────
# NAVIGATEUR
# ─────────────────────────────────────────────
BROWSER_HEADLESS=false

# ─────────────────────────────────────────────
# LOGS
# ─────────────────────────────────────────────
# true = tous les détails | false = actions importantes uniquement
VERBOSE=false

# ─────────────────────────────────────────────
# HOTSPOT / PORTAIL CAPTIF
# ─────────────────────────────────────────────
HOTSPOT_URL=http://hotspot.ci/login
HOTSPOT_SUCCESS_URLS=http://hotspot.ci/status,http://hotspot.ci/success.html
HOTSPOT_COOKIE_PATH=cookies/cookies_hotspot.json

# ─────────────────────────────────────────────
# SÉLECTEURS CSS (adapter selon le portail)
# ─────────────────────────────────────────────
SELECTOR_INPUT=input#username
SELECTOR_BUTTON=form button.btn
SELECTOR_ERROR=form[name="login"] .error
SELECTOR_SUCCESS_TEXT=cliquer ici|click here

# ─────────────────────────────────────────────
# GÉNÉRATION DES CODES
# ─────────────────────────────────────────────
# Répéter un préfixe pour augmenter sa probabilité d'apparition
CODE_PREFIXES=4j,4j,4j,4j,4d,1s
CODE_MIN_LEN=6
CODE_MAX_LEN=7
# lower | upper | both
CODE_CHARSET=lower

# ─────────────────────────────────────────────
# VÉRIFICATION DE CONNEXION (PING)
# ─────────────────────────────────────────────
PING_URLS=http://www.google.com,http://1.1.1.1,http://www.cloudflare.com
PING_RETRIES=3
PING_TIMEOUT_MS=5000

# ─────────────────────────────────────────────
# DÉLAIS ENTRE TENTATIVES
# ─────────────────────────────────────────────
DELAY_MIN_SEC=15
DELAY_MAX_SEC=45
WIFI_DOWN_MAX_WAITS=20
WIFI_RECONNECT_EXTRA_MIN_SEC=10
WIFI_RECONNECT_EXTRA_MAX_SEC=30

# ─────────────────────────────────────────────
# BOUCLE PRINCIPALE
# ─────────────────────────────────────────────
MAX_ITERATIONS=1000
